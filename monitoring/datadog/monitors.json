{
  "monitors": [
    {
      "name": "High Error Rate",
      "type": "metric alert",
      "query": "avg(last_5m):avg:betting.platform.http.requests.5xx{*} / avg:betting.platform.http.requests{*} > 0.1",
      "message": "High error rate detected on betting platform. Error rate is {{value}}%.\n\n@pagerduty-service-betting-platform @slack-betting-platform-alerts",
      "tags": ["env:production", "service:betting-platform", "severity:warning"],
      "options": {
        "notify_audit": false,
        "locked": false,
        "timeout_h": 0,
        "no_data_timeframe": null,
        "include_tags": true,
        "new_host_delay": 300,
        "require_full_window": false,
        "notify_no_data": false,
        "renotify_interval": 0,
        "escalation_message": "",
        "thresholds": {
          "critical": 0.2,
          "warning": 0.1
        }
      }
    },
    {
      "name": "High Latency",
      "type": "metric alert",
      "query": "p95(last_5m):avg:betting.platform.http.request.duration{*} > 0.5",
      "message": "High latency detected on betting platform. 95th percentile latency is {{value}}s.\n\n@pagerduty-service-betting-platform @slack-betting-platform-alerts",
      "tags": ["env:production", "service:betting-platform", "severity:warning"],
      "options": {
        "notify_audit": false,
        "locked": false,
        "timeout_h": 0,
        "no_data_timeframe": null,
        "include_tags": true,
        "new_host_delay": 300,
        "require_full_window": false,
        "notify_no_data": false,
        "renotify_interval": 0,
        "escalation_message": "",
        "thresholds": {
          "critical": 1.0,
          "warning": 0.5
        }
      }
    },
    {
      "name": "Service Down",
      "type": "service check",
      "query": "('up').over('service:betting-platform').last(2).count_by_status() == 0",
      "message": "Betting platform service is down.\n\n@pagerduty-service-betting-platform @slack-betting-platform-alerts",
      "tags": ["env:production", "service:betting-platform", "severity:critical"],
      "options": {
        "notify_audit": false,
        "locked": false,
        "timeout_h": 0,
        "no_data_timeframe": 2,
        "include_tags": true,
        "new_host_delay": 300,
        "require_full_window": false,
        "notify_no_data": true,
        "renotify_interval": 0,
        "escalation_message": ""
      }
    },
    {
