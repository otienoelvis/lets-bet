SERVICE_NAME=betting-platform
ENVIRONMENT=development
PORT=8080

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=betting_db
DATABASE_USER=betting_user
DATABASE_PASSWORD=betting_pass_2026
DATABASE_SSL_MODE=disable  # require in production

# Connection pool
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=5m

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

NATS_URL=nats://localhost:4222

COUNTRY_CODE=KE  # KE, NG, GH
CURRENCY=KES     # KES, NGN, GHS
TIMEZONE=Africa/Nairobi


# M-Pesa (Kenya - Safaricom Daraja API)
MPESA_ENVIRONMENT=sandbox  # sandbox or production
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_SHORTCODE=174379  # Your Paybill/Till number
MPESA_PASSKEY=your_passkey_here
MPESA_INITIATOR_NAME=your_initiator_name
MPESA_SECURITY_CREDENTIAL=your_encrypted_credential
MPESA_CALLBACK_URL=https://yourdomain.com/api/mpesa/callback
MPESA_TIMEOUT_URL=https://yourdomain.com/api/mpesa/timeout
MPESA_RESULT_URL=https://yourdomain.com/api/mpesa/b2c-result

# Airtel Money (Kenya)
AIRTEL_CLIENT_ID=your_client_id
AIRTEL_CLIENT_SECRET=your_client_secret
AIRTEL_SHORTCODE=your_shortcode

# Paystack (Nigeria)
PAYSTACK_SECRET_KEY=your_secret_key
PAYSTACK_PUBLIC_KEY=your_public_key

# Flutterwave (Multi-country)
FLUTTERWAVE_SECRET_KEY=your_secret_key
FLUTTERWAVE_PUBLIC_KEY=your_public_key

SPORTRADAR_API_KEY=your_api_key
SPORTRADAR_API_URL=https://api.sportradar.com

BETGENIUS_API_KEY=your_api_key
BETGENIUS_API_URL=https://api.betgenius.com

SMILE_ID_API_KEY=your_api_key
SMILE_ID_PARTNER_ID=your_partner_id

METAMAP_CLIENT_ID=your_client_id
METAMAP_CLIENT_SECRET=your_client_secret

JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=168h  # 7 days

BCRYPT_COST=12
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

CRASH_TICK_INTERVAL=100ms  # Update frequency (100ms = 10x per second)
CRASH_MIN_BET=10           # Minimum bet in currency
CRASH_MAX_BET=10000        # Maximum bet in currency
CRASH_MAX_MULTIPLIER=100   # Maximum possible crash point
CRASH_HOUSE_EDGE=0.01      # 1% house edge

MIN_BET_STAKE=10
MAX_BET_STAKE=100000
MAX_SELECTIONS_MULTI=20
MAX_SELECTIONS_SYSTEM=15

TAX_GGR_RATE=0.15          # 15% on Gross Gaming Revenue
TAX_WHT_RATE=0.20          # 20% Withholding Tax on winnings
TAX_THRESHOLD=500          # Minimum winning amount subject to tax

DEFAULT_DAILY_DEPOSIT_LIMIT=50000    # KES 50,000
DEFAULT_SELF_EXCLUSION_PERIOD=30d    # 30 days
MIN_AGE=18

LOG_LEVEL=info  # debug, info, warn, error
LOG_FORMAT=json # json or text

SENTRY_DSN=your_sentry_dsn
DATADOG_API_KEY=your_datadog_key

AWS_REGION=af-south-1  # Cape Town
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# S3 for document uploads (KYC)
S3_BUCKET_NAME=betting-platform-kyc-documents
S3_BUCKET_REGION=af-south-1

CLOUDFLARE_API_TOKEN=your_api_token
CLOUDFLARE_ZONE_ID=your_zone_id

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@yourdomain.com

AFRICASTALKING_API_KEY=your_api_key
AFRICASTALKING_USERNAME=your_username

FEATURE_LIVE_BETTING=true
FEATURE_CRASH_GAMES=true
FEATURE_VIRTUAL_SPORTS=false
FEATURE_JACKPOTS=false
FEATURE_CASINO=false

DEBUG_MODE=false
ENABLE_SWAGGER=true
ENABLE_PPROF=false
